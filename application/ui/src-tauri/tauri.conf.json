{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "geti_ui",
    "version": "0.1.0",
    "identifier": "com.intel",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "Geti Instant Learn",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "externalBin": ["instant-learn-backend"],
        "resources": ["_internal", "InitialData"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ]
    }
}
